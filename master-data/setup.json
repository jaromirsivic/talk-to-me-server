{
  "version": 1,
  "network": {
    "ipv4Address": "127.0.0.1",
    "ipv4Enabled": true,
    "ipv6Address": "::1",
    "ipv6Enabled": true,
    "port": 44448,
    "remoteManagementEnabled": true
  },
  "voice": {
    "tts": "Piper",
